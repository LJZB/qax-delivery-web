  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Obtener todos los usuarios",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users",
            "description": "Obtiene todos los usuarios almacenados en memoria."
          }
        },
        {
          "name": "Obtener un usuario por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/1",
            "description": "Obtiene el usuario inicial con ID 1."
          }
        },
        {
          "name": "Crear un nuevo usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Bloque de preparación:",
                  "// Guarda el ID real para que la petición DELETE elimine el recurso creado.",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('createdUserId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"UsuarioQA\",\n  \"email\": \"usuarioqa@test.com\"\n}"
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Crea un usuario ficticio para la práctica local."
          }
        },
        {
          "name": "Eliminar el usuario creado",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{createdUserId}}",
            "description": "Elimina el usuario creado por la petición POST."
          }
        },
        {
          "name": "Error 404 - usuario inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/999",
            "description": "Consulta un ID inexistente para obtener la evidencia del estado 404."
          }
        }
      ]
    },

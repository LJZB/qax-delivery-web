            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"UsuarioQA\",\n  \"productoId\": 1,\n  \"cantidad\": 1\n}"
            },
            "url": "{{baseUrl}}/api/orders",
            "description": "Crea una orden ficticia con estado inicial pendiente."
          }
        },
